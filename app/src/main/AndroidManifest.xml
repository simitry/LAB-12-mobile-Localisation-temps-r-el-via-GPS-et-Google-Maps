<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Allows the app to receive precise GPS coordinates. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Allows the app to receive approximate location if the device provides it. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Allows Volley to send HTTP requests to the PHP backend. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Allows the optional TelephonyManager fallback only when the user grants it. -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LocalisationLab12"
        android:usesCleartextTraffic="true">

        <!-- Provides the Google Maps API key used by SupportMapFragment. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />

        <!-- Declares the activity that displays saved positions on Google Maps. -->
        <activity
            android:name=".MapsActivity"
            android:exported="false"
            android:label="@string/title_activity_maps" />
        <!-- Declares the launcher activity that collects and sends GPS coordinates. -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <!-- Makes MainActivity the application entry point. -->
            <intent-filter>
                <!-- Marks this activity as the main app action. -->
                <action android:name="android.intent.action.MAIN" />

                <!-- Shows this activity in the launcher. -->
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
